# ─────────────────────────────────────────────────────────────
# CareerPilot AI – Backend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbName>?retryWrites=true&w=majority
# Get this from: Atlas → Clusters → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/careerpilot?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ─── AI / Gemini ──────────────────────────────────────────────
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Testing ──────────────────────────────────────────────────
# Timeout (ms) for Jest DB tests on slow Atlas connections (default: 30000)
TEST_TIMEOUT=30000

# Log level: debug | info | warn | error | none
LOG_LEVEL=info
