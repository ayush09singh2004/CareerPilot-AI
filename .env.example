# CareerPilot AI - Environment Configuration

# ----------------------------------------------------
# BACKEND (.env in /backend)
# ----------------------------------------------------
NODE_ENV=development
PORT=5000

# MongoDB Connection String (Required)
# Use mongodb://localhost:27017/careerpilot for local
# Use mongodb+srv://<user>:<password>@cluster.mongodb.net/careerpilot for Atlas
MONGODB_URI=mongodb://localhost:27017/careerpilot

# JWT Secret for Session Management (Required)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Google Gemini API Key for AI Analysis Features (Required)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------------------------------------------
# FRONTEND (.env in /frontend)
# ----------------------------------------------------
# Base URL for the Backend API (Required for Production)
# Leave blank for local development (defaults to http://localhost:5000/api)
VITE_API_URL=https://your-render-backend-url.onrender.com/api
